<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/inventoryActivity"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:ignore="HardcodedText"
    android:background="@color/black"
    tools:context=".InventoryScreen">
        <ImageView
            android:id="@+id/backgroundImg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="0dp"
            android:background="@drawable/day_background"
            android:scaleType="centerCrop"
            android:src="@drawable/day_background" />
    <Button
        android:id="@+id/open_main_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.33"
        app:layout_constraintHeight_percent="0.08"
        android:background="@drawable/sharp_rectangle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <Button
        android:id="@+id/changeToInventory"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.33"
        app:layout_constraintHeight_percent="0.08"
        android:background="@drawable/sharp_rectangle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <Button
        android:id="@+id/open_sounds_button"

        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.33"
        app:layout_constraintHeight_percent="0.08"
        android:background="@drawable/sharp_rectangle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <LinearLayout
        android:id="@+id/activeTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.05"
        >
        <ImageButton
            android:id="@+id/active0"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_marginEnd="40dp"/>
        <ImageButton
            android:id="@+id/active1"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/activeBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/activeTop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.01"
        >
        <ImageButton
            android:id="@+id/active2"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_marginEnd="30dp"/>
        <ImageButton
            android:id="@+id/active3"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_marginEnd="30dp"/>
        <ImageButton
            android:id="@+id/active4"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/earn_treat_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/activeBottom"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        app:layout_constraintVertical_bias="0.01"
        >
        <TextView
            android:id = "@+id/treat_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0" />
        <TextView
            android:id = "@+id/earn_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0" />
    </LinearLayout>
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="6"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/earn_treat_view"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.1"
        android:useDefaultMargins="true"
        tools:ignore="NotSibling">

        <ImageButton
            android:id="@+id/inventory0"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory1"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory2"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory3"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory4"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory5"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory6"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory7"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory8"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory9"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory10"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory11"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/inv_background"
            android:background="@null"
            android:scaleType="centerCrop"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
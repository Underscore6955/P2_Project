<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:ignore="HardcodedText"
    tools:context=".MainActivity">

    <LinearLayout
        android:adjustViewBounds="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:ignore="MissingConstraints">
        <!--a sample image view for the preview purpose-->
        <ImageView
            android:id="@+id/backgroundImg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="0dp"
            android:scaleType="centerCrop"
            android:background="@drawable/day_background"
            android:src="@drawable/day_background" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/activeTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.05"
        >
        <ImageButton
            android:id="@+id/active0"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/inv_background"
            android:layout_marginEnd="40dp"/>
        <ImageButton
            android:id="@+id/active1"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/inv_background"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/activeTop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.01"
        >
        <ImageButton
            android:id="@+id/active2"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/inv_background"
            android:layout_marginEnd="30dp"/>
        <ImageButton
            android:id="@+id/active3"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/inv_background"
            android:layout_marginEnd="30dp"/>
        <ImageButton
            android:id="@+id/active4"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/inv_background"/>
    </LinearLayout>
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="6"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.5"
        android:useDefaultMargins="true">

        <ImageButton
            android:id="@+id/inventory0"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory1"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory2"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory3"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory4"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory5"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory6"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory7"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory8"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory9"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory10"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>

        <ImageButton
            android:id="@+id/inventory11"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/inv_background"
            android:layout_columnWeight="1"
            android:layout_gravity="center"
            android:layout_rowWeight="1"/>
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
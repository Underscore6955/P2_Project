<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/music_player"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#151221"
    tools:context=".AudioPlayer">

    <TextView
        android:id="@+id/header_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="48dp"
        android:text="Listening to:"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/sound1_image"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="32dp"
        android:clickable="true"
        android:focusable="true"
        android:background="#FFFFFF"
        android:scaleType="fitCenter"
        android:padding="16dp"
        app:layout_constraintEnd_toStartOf="@+id/sound2_image"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_text"
        android:src="@drawable/add_box_24px" />

    <TextView
        android:id="@+id/sound1_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Add a sound"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@+id/sound1_image"
        app:layout_constraintStart_toStartOf="@+id/sound1_image"
        app:layout_constraintTop_toBottomOf="@+id/sound1_image" />

    <ImageView
        android:id="@+id/sound1_heart"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/uchecked_favorite_24px"
        app:layout_constraintEnd_toEndOf="@+id/sound1_text"
        app:layout_constraintStart_toStartOf="@+id/sound1_text"
        app:layout_constraintTop_toBottomOf="@+id/sound1_text"
        app:tint="#8B0000" />

    <ImageView
        android:id="@+id/sound2_image"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:clickable="true"
        android:focusable="true"
        android:background="#FFFFFF"
        android:scaleType="fitCenter"
        android:padding="16dp"
        android:src="@drawable/add_box_24px"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/sound1_image"
        app:layout_constraintTop_toTopOf="@+id/sound1_image" />

    <TextView
        android:id="@+id/sound2_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Add a sound"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@+id/sound2_image"
        app:layout_constraintStart_toStartOf="@+id/sound2_image"
        app:layout_constraintTop_toBottomOf="@+id/sound2_image" />

    <ImageView
        android:id="@+id/sound2_heart"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/uchecked_favorite_24px"
        app:layout_constraintEnd_toEndOf="@+id/sound2_text"
        app:layout_constraintStart_toStartOf="@+id/sound2_text"
        app:layout_constraintTop_toBottomOf="@+id/sound2_text"
        app:tint="#8B0000" />

    <TextView
        android:id="@+id/tv_volume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Volume"
        android:textColor="#FFFFFF"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sound1_heart" />
    <ImageButton
        android:id="@+id/open_stories"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:layout_constraintBottom_toTopOf="@id/changeToInventory"
        app:layout_constraintEnd_toEndOf="parent"
        android:scaleType="centerCrop"
        android:layout_marginBottom="30dp"
        android:layout_marginRight="30dp"
        android:src="@drawable/book"
        android:background="@null"
        />

    <SeekBar
        android:id="@+id/seekbar_volume"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="50"
        android:progressTint="#A9A9A9"
        android:thumbTint="#A9A9A9"
        android:progressBackgroundTint="#000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_volume" />

    <TextView
        android:id="@+id/tv_pitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Pitch"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textAllCaps="true"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/seekbar_volume" />

    <SeekBar
        android:id="@+id/seekbar_pitch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="50"
        android:progressTint="#A9A9A9"
        android:thumbTint="#A9A9A9"
        android:progressBackgroundTint="#000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_pitch" />

    <ImageView
        android:id="@+id/btn_play_pause"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/play_circle_24px"
        android:clickable="true"
        android:focusable="true"
        app:tint="#D3D3D3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/seekbar_pitch"
        app:layout_constraintBottom_toBottomOf="@+id/open_main_button"/>

    <ImageView
        android:id="@+id/btn_pause"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/pause_circle_24px"
        android:visibility="invisible"
        app:tint="#D3D3D3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/seekbar_pitch"
        app:layout_constraintBottom_toBottomOf="@+id/open_main_button" />
    <Button
        android:id="@+id/open_main_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.33"
        app:layout_constraintHeight_percent="0.08"
        android:background="@drawable/sharp_rectangle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintHeight_percent="0.09"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="@id/open_main_button"
        app:layout_constraintEnd_toEndOf="@id/open_main_button"
        app:layout_constraintBottom_toBottomOf="@id/open_main_button"
        android:src="@drawable/home_icon"
        android:background="@null"
        />
    <Button
        android:id="@+id/changeToInventory"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.33"
        app:layout_constraintHeight_percent="0.08"
        android:background="@drawable/sharp_rectangle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintHeight_percent="0.09"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="@id/changeToInventory"
        app:layout_constraintEnd_toEndOf="@id/changeToInventory"
        app:layout_constraintBottom_toBottomOf="@id/changeToInventory"
        android:src="@drawable/inventory_icon"
        android:background="@null"
        />
    <Button
        android:id="@+id/open_sounds_button"

        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.33"
        app:layout_constraintHeight_percent="0.08"
        android:background="@drawable/sharp_rectangle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintHeight_percent="0.09"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="@id/open_sounds_button"
        app:layout_constraintEnd_toEndOf="@id/open_sounds_button"
        app:layout_constraintBottom_toBottomOf="@id/open_sounds_button"
        android:src="@drawable/sound_icon"
        android:background="@null"
        />

</androidx.constraintlayout.widget.ConstraintLayout>
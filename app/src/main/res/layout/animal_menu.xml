<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
<View
    android:id="@+id/menu_box"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:adjustViewBounds="true"
    app:layout_constraintWidth_percent="0.8"
    app:layout_constraintHeight_percent="0.7"
    android:background="@android:color/darker_gray"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"

        app:layout_constraintTop_toTopOf="@id/menu_box"
        app:layout_constraintBottom_toBottomOf="@id/menu_box"
        app:layout_constraintStart_toStartOf="@id/menu_box"
        app:layout_constraintEnd_toEndOf="@id/menu_box">

        <Button
            android:id="@+id/close_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.95"
            app:layout_constraintWidth_percent="0.15"
            app:layout_constraintHeight_percent="0.08"
            android:layout_marginTop="10dp"
            android:backgroundTint="@android:color/holo_red_light"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/close_button"
            app:layout_constraintBottom_toBottomOf="@id/close_button"
            app:layout_constraintStart_toStartOf="@id/close_button"
            app:layout_constraintEnd_toEndOf="@id/close_button"
            android:text="Close"
            android:textSize="15sp"
            />
        <TextView
            android:id="@+id/animal_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello"
            android:textSize="50sp"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        <TextView
            android:id="@+id/earn_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/animal_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="howdy\npartner"/>
        <ImageView
            android:id="@+id/animal_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/donkey"
            android:scaleType="fitCenter"

            app:layout_constraintWidth_percent="0.5"
            app:layout_constraintHeight_percent="0.5"

            app:layout_constraintTop_toBottomOf="@id/earn_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        <ProgressBar
            android:id="@+id/xp_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.9"
            app:layout_constraintHeight_percent="0.08"
            app:layout_constraintTop_toBottomOf="@id/animal_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:progress="25"/>
        <TextView
            android:id="@+id/xp_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/xp_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="5dp"
            android:textSize="20sp"
            android:text="30% of the way to level 2"/>
        <Button
            android:id="@+id/equip_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.9"
            app:layout_constraintWidth_percent="0.2"
            app:layout_constraintHeight_percent="0.08"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@android:color/holo_green_light"
            />
        <TextView
            android:id="@+id/equip_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/equip_button"
            app:layout_constraintBottom_toBottomOf="@id/equip_button"
            app:layout_constraintStart_toStartOf="@id/equip_button"
            app:layout_constraintEnd_toEndOf="@id/equip_button"
            android:text="Equip"
            android:textSize="15sp"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
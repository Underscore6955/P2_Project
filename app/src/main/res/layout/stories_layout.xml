<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/menu_box"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintHeight_percent="0.7"
        android:background="@android:color/darker_gray"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <GridLayout
        android:id="@+id/grid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/menu_box"
        app:layout_constraintEnd_toEndOf="@id/menu_box"
        app:layout_constraintTop_toTopOf="@id/menu_box"
        app:layout_constraintBottom_toBottomOf="@id/menu_box"

        android:columnCount="3">

        <!-- FOX 1 -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_margin="16dp"
            android:layout_gravity="center">


            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <!-- Base image -->
                <ImageButton
                    android:id="@+id/fox1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/fox"
                    android:background="@null"
                    android:scaleType="centerCrop"/>

                <!-- Lock overlay -->
                <ImageView
                    android:id="@+id/lock_fox1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/lock"
                    android:layout_gravity="center"
                    android:visibility="visible"/>
                <!-- use "gone" when unlocked -->

            </FrameLayout>

            <TextView
                android:text="Fox 1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"/>
        </LinearLayout>

